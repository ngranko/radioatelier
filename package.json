{
    "name": "Radioatelier. Archive",
    "version": "0.8.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently 'convex dev' 'vite dev'",
        "build": "vite build",
        "start": "node build/index.js",
        "preview": "vite preview",
        "deploy": "convex deploy --cmd 'npm run build'",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "oxlint --fix . && eslint --fix 'src/**/*.svelte' && oxfmt .",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "oxfmt ."
    },
    "dependencies": {
        "@convex-dev/migrations": "^0.3.5",
        "@deck.gl/core": "^9.3.7",
        "@deck.gl/google-maps": "^9.3.7",
        "@deck.gl/layers": "^9.3.7",
        "@googlemaps/js-api-loader": "^2.1.1",
        "@lucide/svelte": "^1.25.0",
        "@luma.gl/webgl": "^9.3.6",
        "@selemondev/svgl-svelte": "^2.17.0",
        "@tailwindcss/vite": "^4.3.3",
        "clsx": "^2.1.1",
        "convex": "^1.42.3",
        "convex-svelte": "^0.14.0",
        "eruda": "^3.4.3",
        "posthog-js": "^1.404.1",
        "posthog-node": "^5.45.2",
        "svelte-clerk": "^1.1.11",
        "svelte-easy-crop": "^5.0.1",
        "svelte-portal": "^2.2.1",
        "svix": "^1.98.0",
        "tailwindcss": "^4.3.3",
        "typesense": "^3.0.6",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@sveltejs/adapter-node": "^5.5.7",
        "@sveltejs/kit": "^2.70.0",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@types/google.maps": "^3.65.2",
        "@types/node": "^26",
        "@typescript-eslint/parser": "^8.64.0",
        "bits-ui": "^2.18.1",
        "bun-types": "^1.3.14",
        "concurrently": "^10",
        "eslint": "^9.39.5",
        "eslint-plugin-svelte": "^3.20.0",
        "formsnap": "^2.0.1",
        "globals": "^15.15.0",
        "mode-watcher": "^1.1.0",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "svelte": "^5.56.6",
        "svelte-check": "^4.7.3",
        "svelte-eslint-parser": "^1.8.0",
        "svelte-sonner": "^1.1.1",
        "sveltekit-superforms": "^2.30.2",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tslib": "^2.8.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "6.0.3",
        "vite": "^8.1.5",
        "vite-plugin-cjs-interop": "^4.0.3",
        "vitest": "^4.1.10"
    },
    "engines": {
        "bun": ">=1.3.8",
        "node": ">=26.0.0"
    }
}
