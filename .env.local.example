# =============================================================================
# Local environment — SvelteKit, Convex CLI, and one-off scripts
# =============================================================================
# Copy to `.env.local` and fill in values for this machine.
#
# Secrets used by Convex functions (Notion, Typesense sync/search, webhooks,
# Google server APIs, Clerk JWT for Convex Auth) belong on the Convex deployment,
# not here. See docs/environment.md and set them with:
#   npx convex env set NAME value
# or in the Convex dashboard → Settings → Environment variables.
# =============================================================================

# --- Convex CLI (not read by app code) ---
CONVEX_DEPLOYMENT=dev:[your-deployment-id]

# --- SvelteKit / browser (PUBLIC_ is exposed to the client) ---
PUBLIC_CONVEX_URL=https://[your-deployment-name].convex.cloud

# Reference URL for HTTP routes on Convex (Clerk/Notion webhooks). Not read by app code.
PUBLIC_CONVEX_SITE_URL=https://[your-deployment-name].convex.site

PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Browser Google Maps (Maps JavaScript API + Map ID). Restrict by HTTP referrer in Google Cloud.
PUBLIC_GOOGLE_MAPS_API_KEY=[your-browser-maps-api-key]
PUBLIC_GOOGLE_MAPS_MAP_ID=[your-google-map-id]

# --- SvelteKit server (Clerk session; never expose to the browser) ---
CLERK_SECRET_KEY=sk_test_xxxxxxx

# --- Local Typesense scripts only (`scripts/typesense/setup.ts`, `typesense:backfill`) ---
# Search/sync keys and collection name are configured in Convex instead.
TYPESENSE_URL=https://[your-deployment-name].typesense.cloud
TYPESENSE_ADMIN_KEY=[your-admin-key]
TYPESENSE_COLLECTION=objects

# Must match TYPESENSE_BACKFILL_KEY on the Convex deployment (backfill script auth).
TYPESENSE_BACKFILL_KEY=[your-backfill-secret]

PUBLIC_POSTHOG_PROJECT_TOKEN=[your-posthog-project-token]
PUBLIC_POSTHOG_HOST=[your-posthog-host]

PUBLIC_GIT_COMMIT_SHA=local
